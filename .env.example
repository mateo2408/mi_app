# Puerto asignado por Render (en local usa 3000).
PORT=3000
# Cadena de conexión MongoDB Atlas.
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster-url>/mi_veterinaria?retryWrites=true&w=majority&appName=<app-name>
# Nombre de la base de datos usada por la app.
MONGO_DB_NAME=mi_veterinaria
# Ajuste de pool para instancia estándar en Render.
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
# Clave para firmar/verificar JWT.
JWT_SECRET=change-this-secret
# Origen permitido para CORS (dominio frontend en Render).
CORS_ORIGIN=https://tu-frontend-render.onrender.com
