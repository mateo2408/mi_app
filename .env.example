# Puerto local de la API Express.
PORT=3000
# Cadena de conexión MongoDB (incluye credenciales de entorno local).
MONGODB_URI=mongodb://root:rootpass@127.0.0.1:27017/mi_veterinaria?authSource=admin
# Clave para firmar/verificar JWT.
JWT_SECRET=change-this-secret
# Origen permitido para CORS (frontend local).
CORS_ORIGIN=http://localhost:4200
